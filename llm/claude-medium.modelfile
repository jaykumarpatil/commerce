# Use 'qwen3.5:122b' for the standard instruct version.
FROM qwen3.5:122b


# Reduce Context: 128k context uses massive VRAM/Compute. 
# 8k-16k is plenty for most coding tasks and much lighter.
PARAMETER num_ctx 16384

# Limit CPU Threads: Prevents Ollama from hogging all performance cores.
# For a Mac Studio (M2/M4 Ultra), 8 threads is a "sweet spot" for background tasks.
PARAMETER num_thread 8

# Lower GPU layers: Instead of 99 (all), try 40-50.
# This forces the Mac to balance the load between CPU and GPU.
PARAMETER num_gpu 50

# Keep the model focused
PARAMETER temperature 0.0